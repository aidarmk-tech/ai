<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.LampaPlayer" parent="Theme.AppCompat.Leanback">
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorPrimaryDark">@color/bg_primary</item>
        <item name="colorAccent">@color/accent_primary</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Theme.LampaPlayer.Player" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorAccent">@color/accent_primary</item>
    </style>

    <style name="Widget.LampaPlayer.Button" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:paddingHorizontal">@dimen/space_md</item>
        <item name="android:paddingVertical">@dimen/space_sm</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="Widget.LampaPlayer.Button.Accent" parent="Widget.LampaPlayer.Button">
        <item name="android:background">@drawable/bg_button_accent</item>
    </style>

    <style name="Widget.LampaPlayer.Pill" parent="Widget.AppCompat.TextView">
        <item name="android:background">@drawable/bg_pill</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingHorizontal">@dimen/space_sm</item>
        <item name="android:paddingVertical">@dimen/space_xs</item>
    </style>

    <!-- Tab label inside the info panel tab strip -->
    <style name="PanelTab" parent="Widget.AppCompat.TextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingHorizontal">@dimen/space_md</item>
        <item name="android:layout_marginEnd">@dimen/space_xs</item>
        <item name="android:background">@drawable/bg_tab</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">false</item>
    </style>
</resources>
