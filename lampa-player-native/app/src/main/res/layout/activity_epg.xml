<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bg_surface"
        android:paddingHorizontal="@dimen/safe_margin">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/epg_title"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Sticky Time Ruler -->
    <HorizontalScrollView
        android:id="@+id/time_ruler_scroll"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:scrollbars="none"
        android:background="@color/bg_surface">

        <LinearLayout
            android:id="@+id/time_ruler"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="240dp" />
    </HorizontalScrollView>

    <!-- EPG Grid -->
    <HorizontalScrollView
        android:id="@+id/epg_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/epg_grid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </HorizontalScrollView>

    <!-- Info Panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:orientation="vertical"
        android:background="@color/bg_surface"
        android:paddingHorizontal="@dimen/safe_margin"
        android:paddingVertical="@dimen/space_sm"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/info_panel_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:hint="Выберите программу" />
    </LinearLayout>
</LinearLayout>
