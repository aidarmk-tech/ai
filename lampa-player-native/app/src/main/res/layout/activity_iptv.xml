<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bg_surface"
        android:paddingHorizontal="@dimen/safe_margin">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/iptv_title"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:fontFamily="sans-serif-medium" />

        <Button
            android:id="@+id/btn_epg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/epg_title"
            android:background="@drawable/bg_button"
            android:textColor="@color/text_primary"
            android:focusable="true"
            android:layout_marginEnd="@dimen/space_sm" />

        <TextView
            android:id="@+id/tv_clock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Content Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Groups Panel -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/group_list"
            android:layout_width="320dp"
            android:layout_height="match_parent"
            android:background="@color/bg_surface"
            android:focusable="true"
            android:descendantFocusability="afterDescendants" />

        <!-- Channels List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/channel_list"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/bg_primary"
            android:focusable="true"
            android:descendantFocusability="afterDescendants" />

        <!-- Preview Panel -->
        <LinearLayout
            android:layout_width="420dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/bg_surface"
            android:padding="@dimen/space_md">

            <androidx.media3.ui.PlayerView
                android:id="@+id/preview_player"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@color/bg_elevated" />

            <TextView
                android:id="@+id/tv_preview_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_preview_show"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_next_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:text="@string/label_next"
                android:textColor="@color/text_disabled"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_next_show"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
