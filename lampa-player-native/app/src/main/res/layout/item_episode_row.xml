<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_card"
    android:focusable="true"
    android:padding="8dp"
    android:layout_marginBottom="8dp">

    <ImageView android:id="@+id/ep_still"
        android:layout_width="148dp"
        android:layout_height="84dp"
        android:scaleType="centerCrop"
        android:background="@color/bg_surface"
        android:layout_marginEnd="12dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <com.lampplayer.tv.player.MarqueeTextView android:id="@+id/tv_ep_name"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" android:textSize="16sp"
            android:fontFamily="sans-serif-medium" />

        <com.lampplayer.tv.player.MarqueeTextView android:id="@+id/tv_ep_overview"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_secondary" android:textSize="13sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>
</LinearLayout>
