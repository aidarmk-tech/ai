<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:keepScreenOn="true">

    <!-- Video (ExoPlayer) -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="false" />

    <!-- Video (libVLC fallback) — shown only when the libVLC engine is active -->
    <org.videolan.libvlc.util.VLCVideoLayout
        android:id="@+id/vlc_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="false"
        android:visibility="gone" />

    <!-- Buffering -->
    <ProgressBar
        android:id="@+id/progress_buffering"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/accent_primary"
        android:visibility="gone" />

    <!-- Reconnecting after a network drop -->
    <TextView
        android:id="@+id/tv_reconnect"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="96dp"
        android:text="Нет соединения · переподключаемся…"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:background="@drawable/bg_channel_card"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:visibility="gone" />

    <!-- ═══ OSD ═══ -->
    <FrameLayout
        android:id="@+id/osd_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- TOP bar -->
        <LinearLayout
            android:id="@+id/top_bar"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_gravity="top"
            android:background="@drawable/bg_osd_gradient_top"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/safe_margin"
            android:paddingTop="@dimen/space_md">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_quality"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_xs"
                android:background="@drawable/bg_pill"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:focusable="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_translator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_xs"
                android:background="@drawable/bg_pill"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:focusable="true"
                android:visibility="gone" />

            <!-- ☰ Info/Episodes button (always visible) -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_sm">

                <ImageButton
                    android:id="@+id/btn_info"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_list"
                    android:scaleType="centerInside"
                    android:padding="12dp"
                    android:background="@drawable/bg_button"
                    android:contentDescription="Серии / Дорожки"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tv_episode_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:background="@drawable/bg_button_accent"
                    android:textColor="@color/text_primary"
                    android:textSize="10sp"
                    android:paddingHorizontal="4dp"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>

        <!-- BOTTOM controls (Infuse-minimal) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_osd_gradient_bottom"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/safe_margin"
            android:paddingTop="@dimen/space_lg"
            android:paddingBottom="@dimen/space_md">

            <!-- Scrubber: фокусируемая полоса прогресса + время по краям -->
            <LinearLayout
                android:id="@+id/scrubber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:focusable="true"
                android:background="@drawable/scrubber_bg"
                android:padding="14dp"
                android:layout_marginBottom="@dimen/space_md">

                <!-- VOD scrubber: progress + elapsed/total. Hidden for IPTV (live). -->
                <LinearLayout android:id="@+id/vod_progress_group"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp">

                        <ProgressBar android:id="@+id/progress_bar"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent" android:layout_height="8dp"
                            android:layout_gravity="center_vertical"
                            android:max="1000" android:progressDrawable="@drawable/bg_progress_track" />

                        <ProgressBar android:id="@+id/seek_indicator"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent" android:layout_height="8dp"
                            android:layout_gravity="center_vertical"
                            android:max="1000"
                            android:progressTint="#88FFFFFF"
                            android:progressBackgroundTint="#00000000"
                            android:visibility="gone" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView android:id="@+id/tv_current_time"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/text_primary" android:textSize="16sp" android:text="0:00" />
                        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
                        <TextView android:id="@+id/tv_duration"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary" android:textSize="16sp" android:text="0:00" />
                    </LinearLayout>
                </LinearLayout>

                <!-- IPTV live bar: LIVE pill + current programme + wall clock. -->
                <LinearLayout android:id="@+id/live_group"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:visibility="gone">

                    <TextView android:id="@+id/tv_live_pill"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="● LIVE"
                        android:textColor="@color/text_primary" android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:background="@drawable/bg_live_pill"
                        android:paddingHorizontal="10dp" android:paddingVertical="3dp"
                        android:layout_marginEnd="12dp" />

                    <TextView android:id="@+id/tv_live_now"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_secondary" android:textSize="15sp"
                        android:maxLines="1" android:ellipsize="end" />

                    <TextView android:id="@+id/tv_clock"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:textColor="@color/text_primary" android:textSize="16sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </LinearLayout>

            <!-- Ряд кнопок (тонкие иконки по центру, прокрутка при переполнении) -->
            <HorizontalScrollView
                android:id="@+id/button_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <ImageButton android:id="@+id/btn_night"
                        android:layout_width="44dp" android:layout_height="44dp"
                        android:src="@drawable/ic_moon"
                        android:scaleType="centerInside" android:padding="11dp"
                        android:background="@drawable/bg_button"
                        android:contentDescription="Ночной режим"
                        android:focusable="true" android:layout_marginHorizontal="6dp" />

                    <ImageButton android:id="@+id/btn_prev"
                        android:layout_width="48dp" android:layout_height="48dp"
                        android:src="@drawable/ic_prev"
                        android:scaleType="centerInside" android:padding="11dp"
                        android:background="@drawable/bg_button"
                        android:contentDescription="Пред. серия"
                        android:focusable="true" android:layout_marginHorizontal="6dp" />

                    <ImageButton android:id="@+id/btn_rewind"
                        android:layout_width="48dp" android:layout_height="48dp"
                        android:src="@drawable/ic_rewind10"
                        android:scaleType="centerInside" android:padding="11dp"
                        android:background="@drawable/bg_button"
                        android:contentDescription="-10с"
                        android:focusable="true" android:layout_marginHorizontal="6dp" />

                    <ImageButton android:id="@+id/btn_play_pause"
                        android:layout_width="60dp" android:layout_height="60dp"
                        android:src="@drawable/ic_play"
                        android:scaleType="centerInside" android:padding="14dp"
                        android:background="@drawable/bg_button_accent"
                        android:contentDescription="Пауза"
                        android:focusable="true" android:layout_marginHorizontal="6dp" />

                    <ImageButton android:id="@+id/btn_forward"
                        android:layout_width="48dp" android:layout_height="48dp"
                        android:src="@drawable/ic_forward10"
                        android:scaleType="centerInside" android:padding="11dp"
                        android:background="@drawable/bg_button"
                        android:contentDescription="+10с"
                        android:focusable="true" android:layout_marginHorizontal="6dp" />

                    <ImageButton android:id="@+id/btn_next"
                        android:layout_width="48dp" android:layout_height="48dp"
                        android:src="@drawable/ic_next"
                        android:scaleType="centerInside" android:padding="11dp"
                        android:background="@drawable/bg_button"
                        android:contentDescription="След. серия"
                        android:focusable="true" android:layout_marginHorizontal="6dp" />

                    <Button android:id="@+id/btn_speed"
                        android:layout_width="wrap_content" android:layout_height="48dp"
                        android:minWidth="56dp"
                        android:paddingHorizontal="12dp"
                        android:text="1×"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textAllCaps="false"
                        android:background="@drawable/bg_button"
                        android:contentDescription="Скорость воспроизведения"
                        android:focusable="true" android:layout_marginHorizontal="6dp" />

                    <Button android:id="@+id/btn_aspect"
                        android:layout_width="wrap_content" android:layout_height="48dp"
                        android:minWidth="64dp"
                        android:paddingHorizontal="12dp"
                        android:text="FIT"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                        android:background="@drawable/bg_button"
                        android:contentDescription="Соотношение / зум"
                        android:focusable="true" android:layout_marginHorizontal="6dp" />

                    <Button android:id="@+id/btn_volume"
                        android:layout_width="wrap_content" android:layout_height="48dp"
                        android:minWidth="64dp"
                        android:paddingHorizontal="12dp"
                        android:text="100%"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                        android:background="@drawable/bg_button"
                        android:contentDescription="Громкость"
                        android:focusable="true" android:layout_marginHorizontal="6dp" />

                    <ImageButton android:id="@+id/btn_settings"
                        android:layout_width="48dp" android:layout_height="48dp"
                        android:src="@drawable/ic_settings"
                        android:scaleType="centerInside" android:padding="11dp"
                        android:background="@drawable/bg_button"
                        android:contentDescription="Настройки"
                        android:focusable="true" android:layout_marginHorizontal="6dp" />
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>
    </FrameLayout>

    <!-- ═══ Seek preview overlay (center) ═══ -->
    <LinearLayout
        android:id="@+id/seek_preview_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_button"
        android:paddingHorizontal="32dp"
        android:paddingVertical="20dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_seek_delta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tv_seek_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="48sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- ═══ Resume card: "Продолжаем с 47:12 · ← Сначала" (auto-hides) ═══ -->
    <LinearLayout
        android:id="@+id/resume_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="@dimen/safe_margin"
        android:layout_marginBottom="220dp"
        android:orientation="vertical"
        android:background="@drawable/bg_channel_card"
        android:padding="@dimen/space_md"
        android:elevation="8dp"
        android:visibility="gone">

        <TextView android:id="@+id/tv_resume_text"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" android:textSize="18sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="←  смотреть сначала"
            android:textColor="@color/text_secondary" android:textSize="14sp" />
    </LinearLayout>

    <!-- ═══ Channel-number zap overlay (IPTV: type a number on the remote) ═══ -->
    <TextView
        android:id="@+id/tv_zap_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="120dp"
        android:layout_marginEnd="@dimen/safe_margin"
        android:background="@drawable/bg_channel_card"
        android:textColor="@color/text_primary"
        android:textSize="56sp"
        android:fontFamily="sans-serif-medium"
        android:minWidth="120dp"
        android:gravity="center"
        android:paddingHorizontal="28dp"
        android:paddingVertical="12dp"
        android:visibility="gone" />

    <!-- Skip Intro -->
    <Button android:id="@+id/btn_skip_intro"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="100dp" android:layout_marginEnd="@dimen/safe_margin"
        android:text="@string/skip_intro"
        android:background="@drawable/bg_button_accent"
        android:textColor="@color/text_primary" android:textSize="18sp"
        android:paddingHorizontal="24dp" android:paddingVertical="12dp"
        android:focusable="true" android:visibility="gone" />

    <!-- Auto-next overlay -->
    <LinearLayout android:id="@+id/auto_next_overlay"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="56dp" android:layout_marginEnd="@dimen/safe_margin"
        android:orientation="vertical"
        android:background="@drawable/bg_button" android:padding="@dimen/space_md"
        android:visibility="gone">
        <TextView android:id="@+id/tv_auto_next_countdown"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" android:textSize="18sp" />
        <Button android:id="@+id/btn_cancel_auto_next"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:text="@string/cancel_autonext"
            android:background="@drawable/bg_button"
            android:textColor="@color/text_primary" android:focusable="true" />
    </LinearLayout>

    <!-- Error overlay -->
    <LinearLayout android:id="@+id/error_container"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:gravity="center"
        android:background="@color/bg_overlay" android:visibility="gone">
        <TextView android:id="@+id/tv_error_message"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/color_error" android:textSize="22sp"
            android:gravity="center" android:paddingHorizontal="@dimen/space_lg"
            android:layout_marginBottom="@dimen/space_md" />
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btn_retry"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/action_retry" android:background="@drawable/bg_button_accent"
                android:textColor="@color/text_primary" android:textSize="18sp"
                android:paddingHorizontal="24dp" android:paddingVertical="12dp"
                android:focusable="true" android:layout_marginEnd="@dimen/space_sm" />
            <Button android:id="@+id/btn_exit"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/action_back" android:background="@drawable/bg_button"
                android:textColor="@color/text_primary" android:textSize="18sp"
                android:paddingHorizontal="24dp" android:paddingVertical="12dp"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- Diagnostics -->
    <TextView android:id="@+id/diag_text"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="top|start" android:layout_margin="@dimen/safe_margin"
        android:background="@drawable/bg_diag" android:fontFamily="monospace"
        android:textColor="@color/text_primary" android:textSize="14sp"
        android:padding="@dimen/space_xs" android:visibility="gone" />

    <!-- Intent diagnostic overlay: shows exactly what arrived in the launch intent -->
    <TextView android:id="@+id/intent_debug"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="top|start" android:layout_margin="@dimen/safe_margin"
        android:background="@drawable/bg_diag" android:fontFamily="monospace"
        android:textColor="#FFE082" android:textSize="13sp"
        android:lineSpacingMultiplier="1.1"
        android:padding="@dimen/space_sm" android:visibility="gone" />

    <!-- ═══ INFO OVERLAY (↓): компактная нижняя карточка, видео видно сверху ═══ -->
    <LinearLayout
        android:id="@+id/info_overlay"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="@dimen/safe_margin"
        android:layout_marginBottom="@dimen/space_md"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_info_panel"
        android:padding="@dimen/space_md"
        android:visibility="gone">

        <!-- Постер -->
        <ImageView android:id="@+id/iv_overlay_poster"
            android:layout_width="186dp"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@color/bg_surface"
            android:layout_marginEnd="@dimen/space_md" />

        <!-- Текстовый блок: название + мета + описание + (раскрываемые) детали -->
        <ScrollView
            android:id="@+id/sv_overlay_meta"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scrollbars="none"
            android:fadeScrollbars="false">

            <LinearLayout
                android:id="@+id/overlay_meta_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView android:id="@+id/tv_overlay_meta_title"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/text_primary" android:textSize="26sp"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2" android:ellipsize="end"
                    android:layout_marginBottom="@dimen/space_xs" />

                <TextView android:id="@+id/tv_overlay_meta_info"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/accent_primary" android:textSize="15sp"
                    android:layout_marginBottom="@dimen/space_sm" />

                <TextView android:id="@+id/tv_overlay_meta_overview"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary" android:textSize="15sp"
                    android:lineSpacingMultiplier="1.2" />

                <!-- EPG -->
                <TextView android:id="@+id/tv_overlay_epg"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:textColor="@color/text_primary" android:textSize="15sp"
                    android:visibility="gone" />

                <!-- Подсказка: раскрыть детали -->
                <TextView android:id="@+id/tv_overlay_more"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:text="▼ Актёры и создатели"
                    android:textColor="@color/accent_primary" android:textSize="14sp"
                    android:visibility="gone" />

                <!-- Лента актёров с фото (раскрывается на ↓) -->
                <TextView android:id="@+id/tv_cast_header"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:text="В ролях"
                    android:textColor="@color/text_primary" android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_cast"
                    android:layout_width="match_parent"
                    android:layout_height="148dp"
                    android:layout_marginTop="6dp"
                    android:clipToPadding="false"
                    android:focusable="true"
                    android:descendantFocusability="afterDescendants"
                    android:visibility="gone" />

                <!-- Раскрываемые детали: Режиссёр / Сценарий / Жанры -->
                <TextView android:id="@+id/tv_overlay_details"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:textColor="@color/text_secondary" android:textSize="14sp"
                    android:lineSpacingMultiplier="1.25"
                    android:visibility="gone" />

                <!-- Формат видео — чистый чип качества -->
                <TextView android:id="@+id/tv_overlay_video_info"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:background="@drawable/bg_pill"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:paddingHorizontal="12dp" android:paddingVertical="6dp"
                    android:visibility="gone" />
            </LinearLayout>
        </ScrollView>

        <!-- Панель «Серии/Каналы» — только когда есть список -->
        <LinearLayout
            android:id="@+id/episodes_panel"
            android:layout_width="360dp"
            android:layout_height="match_parent"
            android:layout_marginStart="@dimen/space_md"
            android:orientation="vertical"
            android:background="@color/bg_elevated"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_episodes_header"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="@string/tab_episodes"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/space_md"
                android:textColor="@color/accent_primary"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:background="@color/bg_surface" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_info_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="@dimen/space_xs"
                android:focusable="true"
                android:descendantFocusability="afterDescendants" />

            <!-- EPG content (только для IPTV когда нет серий) -->
            <TextView
                android:id="@+id/tv_epg_content"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="@dimen/space_md"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- ═══ TRACKS OVERLAY (↑): аудио + субтитры ═══ -->
    <LinearLayout
        android:id="@+id/tracks_overlay"
        android:layout_width="600dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="horizontal"
        android:background="@color/bg_elevated"
        android:visibility="gone">

        <!-- Аудио дорожки -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/tab_audio"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/space_md"
                android:textColor="@color/accent_primary"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:background="@color/bg_surface" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_audio_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="@dimen/space_xs"
                android:focusable="true"
                android:descendantFocusability="afterDescendants" />
        </LinearLayout>

        <!-- Субтитры -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@color/bg_elevated">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/tab_subtitles"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/space_md"
                android:textColor="@color/accent_primary"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:background="@color/bg_surface" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_subtitle_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="@dimen/space_xs"
                android:focusable="true"
                android:descendantFocusability="afterDescendants" />
        </LinearLayout>
    </LinearLayout>

    <!-- ═══ TMDB Metadata overlay ═══ -->
    <LinearLayout
        android:id="@+id/metadata_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:background="@color/bg_overlay"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.72"
            android:background="@drawable/bg_metadata_overlay"
            android:orientation="horizontal"
            android:padding="@dimen/safe_margin"
            android:gravity="center_vertical">

            <ImageView android:id="@+id/iv_meta_poster"
                android:layout_width="200dp"
                android:layout_height="300dp"
                android:scaleType="centerCrop"
                android:background="@color/bg_elevated"
                android:layout_marginEnd="@dimen/space_lg" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView android:id="@+id/tv_meta_title"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/text_primary" android:textSize="34sp"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2" android:ellipsize="end"
                    android:layout_marginBottom="@dimen/space_sm" />

                <TextView android:id="@+id/tv_meta_info"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/accent_primary" android:textSize="18sp"
                    android:layout_marginBottom="@dimen/space_md" />

                <TextView android:id="@+id/tv_meta_overview"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary" android:textSize="18sp"
                    android:lineSpacingMultiplier="1.25"
                    android:maxLines="6" android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="0.28" />
    </LinearLayout>

    <!-- ═══ CHANNEL CARD (IPTV): slides up on channel switch, auto-hides ═══ -->
    <LinearLayout
        android:id="@+id/channel_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="@dimen/safe_margin"
        android:layout_marginBottom="220dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_channel_card"
        android:padding="@dimen/space_md"
        android:elevation="8dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_card_logo"
            android:layout_width="72dp"
            android:layout_height="48dp"
            android:layout_gravity="center_vertical"
            android:scaleType="fitCenter"
            android:layout_marginEnd="@dimen/space_md"
            android:visibility="gone" />

        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="@dimen/space_md"
            android:background="@drawable/bg_accent_bar" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView android:id="@+id/tv_card_channel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:maxWidth="560dp"
                android:textColor="@color/text_primary" android:textSize="22sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1" android:ellipsize="end" />

            <TextView android:id="@+id/tv_card_now"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:maxWidth="560dp"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_primary" android:textSize="16sp"
                android:maxLines="1" android:ellipsize="end" />

            <TextView android:id="@+id/tv_card_next"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:maxWidth="560dp"
                android:layout_marginTop="3dp"
                android:textColor="@color/text_secondary" android:textSize="14sp"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
