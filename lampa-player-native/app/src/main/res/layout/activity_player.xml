<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:keepScreenOn="true">

    <!-- Video -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="false" />

    <!-- Buffering -->
    <ProgressBar
        android:id="@+id/progress_buffering"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/accent_primary"
        android:visibility="gone" />

    <!-- ═══ OSD ═══ -->
    <FrameLayout
        android:id="@+id/osd_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- TOP bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_gravity="top"
            android:background="@drawable/bg_osd_gradient_top"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/safe_margin"
            android:paddingTop="@dimen/space_md">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_quality"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_xs"
                android:background="@drawable/bg_pill"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:focusable="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_translator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_xs"
                android:background="@drawable/bg_pill"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:focusable="true"
                android:visibility="gone" />

            <!-- Бейдж текущей серии -->
            <TextView
                android:id="@+id/tv_episode_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_xs"
                android:background="@drawable/bg_button_accent"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/space_sm"
                android:src="@android:drawable/ic_menu_preferences"
                android:background="@drawable/bg_button"
                android:contentDescription="Настройки"
                android:focusable="true" />
        </LinearLayout>

        <!-- BOTTOM controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_osd_gradient_bottom"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/safe_margin"
            android:paddingBottom="@dimen/space_md"
            android:gravity="bottom">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView android:id="@+id/tv_current_time"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/text_primary" android:textSize="18sp" android:text="0:00" />
                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
                <TextView android:id="@+id/tv_duration"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary" android:textSize="18sp" android:text="0:00" />
            </LinearLayout>

            <!-- Полоска перемотки (фокусируемая: ←/→ перематывают только когда она в фокусе) -->
            <FrameLayout
                android:id="@+id/progress_focus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_sm"
                android:paddingVertical="10dp"
                android:background="@drawable/bg_progress_focus"
                android:focusable="true"
                android:focusableInTouchMode="false">

                <ProgressBar android:id="@+id/progress_bar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent" android:layout_height="6dp"
                    android:layout_gravity="center_vertical"
                    android:max="1000" android:progressDrawable="@drawable/bg_progress_track" />

                <!-- Seek target indicator (white, semi-transparent) -->
                <ProgressBar android:id="@+id/seek_indicator"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent" android:layout_height="6dp"
                    android:layout_gravity="center_vertical"
                    android:max="1000"
                    android:progressTint="#88FFFFFF"
                    android:progressBackgroundTint="#00000000"
                    android:visibility="gone" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/osd_buttons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <ImageButton android:id="@+id/btn_prev"
                    android:layout_width="48dp" android:layout_height="48dp"
                    android:src="@android:drawable/ic_media_previous"
                    android:background="@drawable/bg_button"
                    android:contentDescription="Пред. серия"
                    android:focusable="true" android:layout_marginHorizontal="6dp" />

                <ImageButton android:id="@+id/btn_rewind"
                    android:layout_width="48dp" android:layout_height="48dp"
                    android:src="@android:drawable/ic_media_rew"
                    android:background="@drawable/bg_button"
                    android:contentDescription="-10с"
                    android:focusable="true" android:layout_marginHorizontal="6dp" />

                <ImageButton android:id="@+id/btn_play_pause"
                    android:layout_width="64dp" android:layout_height="64dp"
                    android:src="@android:drawable/ic_media_play"
                    android:background="@drawable/bg_button_accent"
                    android:contentDescription="Пауза"
                    android:focusable="true" android:layout_marginHorizontal="6dp" />

                <ImageButton android:id="@+id/btn_forward"
                    android:layout_width="48dp" android:layout_height="48dp"
                    android:src="@android:drawable/ic_media_ff"
                    android:background="@drawable/bg_button"
                    android:contentDescription="+10с"
                    android:focusable="true" android:layout_marginHorizontal="6dp" />

                <ImageButton android:id="@+id/btn_next"
                    android:layout_width="48dp" android:layout_height="48dp"
                    android:src="@android:drawable/ic_media_next"
                    android:background="@drawable/bg_button"
                    android:contentDescription="След. серия"
                    android:focusable="true" android:layout_marginHorizontal="6dp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- ═══ Seek preview overlay (center) ═══ -->
    <LinearLayout
        android:id="@+id/seek_preview_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_button"
        android:paddingHorizontal="32dp"
        android:paddingVertical="20dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_seek_delta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tv_seek_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="48sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Skip Intro -->
    <Button android:id="@+id/btn_skip_intro"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="100dp" android:layout_marginEnd="@dimen/safe_margin"
        android:text="@string/skip_intro"
        android:background="@drawable/bg_button_accent"
        android:textColor="@color/text_primary" android:textSize="18sp"
        android:paddingHorizontal="24dp" android:paddingVertical="12dp"
        android:focusable="true" android:visibility="gone" />

    <!-- Auto-next overlay -->
    <LinearLayout android:id="@+id/auto_next_overlay"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="56dp" android:layout_marginEnd="@dimen/safe_margin"
        android:orientation="vertical"
        android:background="@drawable/bg_button" android:padding="@dimen/space_md"
        android:visibility="gone">
        <TextView android:id="@+id/tv_auto_next_countdown"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" android:textSize="18sp" />
        <Button android:id="@+id/btn_cancel_auto_next"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:text="@string/cancel_autonext"
            android:background="@drawable/bg_button"
            android:textColor="@color/text_primary" android:focusable="true" />
    </LinearLayout>

    <!-- Error overlay -->
    <LinearLayout android:id="@+id/error_container"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:gravity="center"
        android:background="@color/bg_overlay" android:visibility="gone">
        <TextView android:id="@+id/tv_error_message"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/color_error" android:textSize="22sp"
            android:gravity="center" android:paddingHorizontal="@dimen/space_lg"
            android:layout_marginBottom="@dimen/space_md" />
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btn_retry"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/action_retry" android:background="@drawable/bg_button_accent"
                android:textColor="@color/text_primary" android:textSize="18sp"
                android:paddingHorizontal="24dp" android:paddingVertical="12dp"
                android:focusable="true" android:layout_marginEnd="@dimen/space_sm" />
            <Button android:id="@+id/btn_exit"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/action_back" android:background="@drawable/bg_button"
                android:textColor="@color/text_primary" android:textSize="18sp"
                android:paddingHorizontal="24dp" android:paddingVertical="12dp"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- Diagnostics -->
    <TextView android:id="@+id/diag_text"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="top|start" android:layout_margin="@dimen/safe_margin"
        android:background="@drawable/bg_diag" android:fontFamily="monospace"
        android:textColor="@color/text_primary" android:textSize="14sp"
        android:padding="@dimen/space_xs" android:visibility="gone" />

    <!-- ═══ ЕДИНАЯ ПАНЕЛЬ (double-↓): вкладки Серии·Аудио·Субтитры·О фильме·EPG ═══ -->
    <LinearLayout
        android:id="@+id/info_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F00B0B12"
        android:visibility="gone">

        <!-- Полоса вкладок -->
        <LinearLayout
            android:id="@+id/tab_strip"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#FF111118"
            android:paddingHorizontal="@dimen/safe_margin">

            <TextView android:id="@+id/tab_episodes"
                style="@style/PanelTab" android:text="@string/tab_episodes" />
            <TextView android:id="@+id/tab_audio"
                style="@style/PanelTab" android:text="@string/tab_audio" />
            <TextView android:id="@+id/tab_subtitles"
                style="@style/PanelTab" android:text="@string/tab_subtitles" />
            <TextView android:id="@+id/tab_about"
                style="@style/PanelTab" android:text="@string/tab_about" />
            <TextView android:id="@+id/tab_epg"
                style="@style/PanelTab" android:text="@string/tab_epg" />
        </LinearLayout>

        <!-- Содержимое вкладок -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="@dimen/safe_margin">

            <!-- Серии -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_info_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:focusable="true"
                android:descendantFocusability="afterDescendants"
                android:visibility="gone" />

            <!-- Аудио -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_audio_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:focusable="true"
                android:descendantFocusability="afterDescendants"
                android:visibility="gone" />

            <!-- Субтитры -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_subtitle_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:focusable="true"
                android:descendantFocusability="afterDescendants"
                android:visibility="gone" />

            <!-- О фильме -->
            <ScrollView
                android:id="@+id/panel_about"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:focusable="true"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageView android:id="@+id/iv_panel_poster"
                        android:layout_width="@dimen/poster_width"
                        android:layout_height="@dimen/poster_height"
                        android:scaleType="centerCrop"
                        android:background="@color/bg_surface"
                        android:layout_marginEnd="@dimen/space_lg" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView android:id="@+id/tv_panel_title"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:textColor="@color/text_primary" android:textSize="30sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="@dimen/space_xs" />

                        <TextView android:id="@+id/tv_panel_info"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:textColor="@color/accent_primary" android:textSize="17sp"
                            android:layout_marginBottom="@dimen/space_md" />

                        <TextView android:id="@+id/tv_panel_overview"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary" android:textSize="17sp"
                            android:lineSpacingMultiplier="1.2" />

                        <TextView android:id="@+id/tv_panel_video_info"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_md"
                            android:background="@drawable/bg_diag"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="monospace" android:textSize="13sp"
                            android:padding="@dimen/space_xs"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>

            <!-- EPG -->
            <TextView
                android:id="@+id/tv_epg_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:focusable="true"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:lineSpacingMultiplier="1.3"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <!-- ═══ TMDB Metadata overlay ═══ -->
    <LinearLayout
        android:id="@+id/metadata_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:background="@color/bg_overlay"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.58"
            android:background="@drawable/bg_metadata_overlay"
            android:orientation="horizontal"
            android:padding="@dimen/safe_margin"
            android:gravity="center_vertical">

            <ImageView android:id="@+id/iv_meta_poster"
                android:layout_width="@dimen/poster_width"
                android:layout_height="@dimen/poster_height"
                android:scaleType="centerCrop"
                android:background="@color/bg_elevated"
                android:layout_marginEnd="@dimen/space_md" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView android:id="@+id/tv_meta_title"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/text_primary" android:textSize="32sp"
                    android:fontFamily="sans-serif-medium" android:layout_marginBottom="@dimen/space_xs" />

                <TextView android:id="@+id/tv_meta_info"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/accent_primary" android:textSize="18sp"
                    android:layout_marginBottom="@dimen/space_sm" />

                <TextView android:id="@+id/tv_meta_overview"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary" android:textSize="18sp"
                    android:maxLines="5" android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="0.42" />
    </LinearLayout>

</FrameLayout>
